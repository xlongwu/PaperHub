{
  "name": "paperhub",
  "version": "0.1.2",
  "productName": "PaperHub",
  "main": "desktop/main.cjs",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "api:dev": "node scripts/dev-api.mjs",
    "mcp:stdio": "node --import tsx src/mcp/index.ts",
    "ui:dev": "node node_modules/vite/bin/vite.js --config vite.ui.config.ts",
    "ui:build": "node node_modules/vite/bin/vite.js build --config vite.ui.config.ts",
    "ui:preview": "node node_modules/vite/bin/vite.js preview --config vite.ui.config.ts",
    "desktop:dev": "node scripts/dev-desktop.mjs",
    "desktop:start": "node scripts/start-desktop.mjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:build:nsis": "node scripts/build-desktop.mjs --nsis",
    "desktop:build:portable": "node scripts/build-desktop.mjs --portable",
    "desktop:build:dir": "node scripts/build-desktop.mjs --dir",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "node node_modules/eslint/bin/eslint.js src",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write src",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check src",
    "manifest": "node --import tsx src/generate-manifest.ts",
    "weekly": "node --import tsx src/weekly.ts",
    "monthly": "node --import tsx src/monthly.ts",
    "notify": "node --import tsx src/notify.ts",
    "notify:feishu": "node --import tsx src/feishu.ts",
    "close-stale": "node --import tsx src/close-stale-issues.ts",
    "xiaohongshu": "node --import tsx src/social.ts xiaohongshu",
    "wechat": "node --import tsx src/social.ts wechat",
    "wechat:monthly": "node --import tsx src/social.ts wechat:monthly",
    "phase6:seed": "node --import tsx scripts/seed-phase6-fixtures.ts --reset",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:e2e": "node --import tsx scripts/run-phase6-e2e.mjs",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "test:coverage": "node node_modules/vitest/vitest.mjs run --coverage",
    "release:verify": "node node_modules/typescript/bin/tsc --noEmit && node node_modules/eslint/bin/eslint.js src && node node_modules/vitest/vitest.mjs run && node node_modules/vite/bin/vite.js build --config vite.ui.config.ts && node --check desktop/main.cjs && node --check scripts/build-desktop.mjs && node --import tsx scripts/run-phase6-e2e.mjs",
    "verify:web-providers": "node --import tsx scripts/verify-web-providers.ts",
    "search:eval": "node --import tsx scripts/evaluate-search.ts --engine v2 --corpus full",
    "search:eval:baseline": "node --import tsx scripts/evaluate-search.ts --engine v1 --corpus full --save",
    "search:eval:save": "node --import tsx scripts/evaluate-search.ts --engine v2 --corpus full --save",
    "search:eval:compare": "node --import tsx scripts/evaluate-search.ts --engine v2 --corpus full --compare --save",
    "arxiv:backfill": "node --import tsx scripts/backfill-arxiv.ts",
    "arxiv:backfill:recent": "node --import tsx scripts/backfill-arxiv.ts --days 30",
    "prepare": "node node_modules/husky/bin.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@tanstack/react-query": "^5.80.7",
    "better-sqlite3": "^12.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.4",
    "node-cron": "^3.0.3",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.2",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.19.0",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "prettier": "^3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.paperhub.desktop",
    "productName": "PaperHub",
    "asar": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist-ui/**/*",
      "desktop/**/*",
      "src/**/*",
      "总结prompt模版.md",
      "skills/**/*",
      "docs/web-content-policy.md",
      "tsconfig.json",
      "package.json",
      "!**/.env",
      "!**/.env.*",
      "!**/*.db",
      "!**/*.sqlite",
      "!**/*.sqlite3",
      "!**/*.log",
      "!data/**",
      "!logs/**",
      "!secrets/**",
      "!digests/**",
      "!src/__tests__/**",
      "!src/test-support/**",
      "!scripts/**",
      "!config.yml",
      "!paperhub.yml"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "PaperHub-${version}-setup-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "PaperHub-${version}-portable-${arch}.${ext}"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
